# Normalize all text files to LF on commit.
* text=auto eol=lf

# Keep shell scripts executable-friendly on Unix-like systems.
*.sh text eol=lf

# Keep Windows scripts with CRLF for better local execution.
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Treat images/fonts as binary.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.woff binary
*.woff2 binary
